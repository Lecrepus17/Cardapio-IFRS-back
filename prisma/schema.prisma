generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Atualizado para os tipos exigidos
enum Role {
  ALUNO
  SERVIDOR
  ADMIN // Recomendado para o usuário que vai cadastrar os cardápios
}

enum MealType {
  ALMOCO
  JANTAR
  CAFEMANHA
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique @db.VarChar(100)
  password  String     @db.VarChar(100)
  role      Role       @default(ALUNO)

  @@map("users")
}

model Menu {
  id        Int        @id @default(autoincrement())
  type      MealType
  date      DateTime   @db.Date
  items     Json       // Armazena o vetor de itens: ["Arroz", "Feijão", "Alface"]

  @@map("menus")
}