generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Atualizado para os tipos exigidos
enum Role {
  ALUNO
  SERVIDOR
  ADMIN // Recomendado para o usuário que vai cadastrar os cardápios
}

enum MealType {
  ALMOCO
  JANTAR
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique @db.VarChar(100)
  password  String     @db.VarChar(100)
  role      Role       @default(ALUNO)
  
  favorites Favorite[] // Relacionamento com os cardápios favoritados

  @@map("users")
}

model Menu {
  id        Int        @id @default(autoincrement())
  type      MealType
  date      DateTime   @db.Date
  items     Json       // Armazena o vetor de itens: ["Arroz", "Feijão", "Alface"]
  
  favorites Favorite[]

  @@map("menus")
}

// Tabela intermediária para gerenciar os favoritos de cada usuário
model Favorite {
  id      Int  @id @default(autoincrement())
  userId  Int  @map("user_id")
  menuId  Int  @map("menu_id")

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  menu    Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([userId, menuId]) // Garante que o usuário não favorite o mesmo cardápio duas vezes
  @@map("favorites")
}